__d(function(g,r,i,a,m,e,d){Object.defineProperty(e,"__esModule",{value:!0}),e.TERMS_VERSION=e.TERMS_OF_SERVICE=void 0;e.TERMS_VERSION='2026-04-27',e.TERMS_OF_SERVICE="## \ube4c\ub77c\ud1a1(ANDNEW) \uc11c\ube44\uc2a4 \uc774\uc6a9\uc57d\uad00\n\n### \uc81c1\uc870 (\ubaa9\uc801)\n\uc774 \uc57d\uad00\uc740 \uc564\ub274(ANDNEW, \uc774\ud558 \"\ud68c\uc0ac\")\uac00 \uc6b4\uc601\ud558\ub294 \"\ube4c\ub77c\ud1a1\"(\uc774\ud558 \"\uc11c\ube44\uc2a4\")\uc758 \uc774\uc6a9 \uc870\uac74 \ubc0f \uc808\ucc28, \ud68c\uc6d0\uacfc \ud68c\uc0ac\uc758 \uad8c\ub9ac\xb7\uc758\ubb34 \ubc0f \ucc45\uc784\uc0ac\ud56d\uc744 \uaddc\uc815\ud568\uc744 \ubaa9\uc801\uc73c\ub85c \ud569\ub2c8\ub2e4.\n\n### \uc81c2\uc870 (\uc6a9\uc5b4\uc758 \uc815\uc758)\n1. \"\uc11c\ube44\uc2a4\"\ub780 \ud68c\uc0ac\uac00 \uc81c\uacf5\ud558\ub294 \ube4c\ub77c\xb7\ub2e4\uc138\ub300 \uacf5\ub3d9\uad00\ub9ac SaaS \ud50c\ub7ab\ud3fc\uc744 \ub9d0\ud569\ub2c8\ub2e4.\n2. \"\uad00\ub9ac\uc790 \ud68c\uc6d0\"\uc774\ub780 \ube4c\ub77c\ub97c \uad00\ub9ac\ud558\ub294 \uc0ac\uc5c5\uc790/\uac1c\uc778\uc774\uba70, \uacb0\uc81c\xb7\uccad\uad6c\xb7\uc785\uc8fc\ubbfc \uad00\ub9ac \uad8c\ud55c\uc744 \uac00\uc9d1\ub2c8\ub2e4.\n3. \"\uc785\uc8fc\ubbfc \ud68c\uc6d0\"\uc774\ub780 \uad00\ub9ac\uc790\uac00 \ub4f1\ub85d\ud55c \uc138\ub300\uc758 \uac70\uc8fc\uc790\ub85c, \uad00\ub9ac\ube44 \uc870\ud68c\xb7\ub0a9\ubd80\xb7\ubbfc\uc6d0 \uae30\ub2a5\uc744 \uc774\uc6a9\ud569\ub2c8\ub2e4.\n4. \"\ucf58\ud150\uce20\"\ub780 \ud68c\uc6d0\uc774 \uc11c\ube44\uc2a4\uc5d0 \uac8c\uc2dc\xb7\uc5c5\ub85c\ub4dc\ud55c \ubaa8\ub4e0 \uc815\ubcf4(\uacf5\uc9c0\xb7\uba54\uc2dc\uc9c0\xb7\uc774\ubbf8\uc9c0 \ub4f1)\ub97c \ub9d0\ud569\ub2c8\ub2e4.\n\n### \uc81c3\uc870 (\uc57d\uad00\uc758 \ud6a8\ub825 \ubc0f \ubcc0\uacbd)\n1. \ubcf8 \uc57d\uad00\uc740 \uc11c\ube44\uc2a4 \ud654\uba74\uc5d0 \uac8c\uc2dc\ud568\uc73c\ub85c\uc368 \ud6a8\ub825\uc774 \ubc1c\uc0dd\ud569\ub2c8\ub2e4.\n2. \ud68c\uc0ac\ub294 \uad00\ub828 \ubc95\ub839\uc744 \uc704\ubc18\ud558\uc9c0 \uc54a\ub294 \ubc94\uc704\uc5d0\uc11c \uc57d\uad00\uc744 \ubcc0\uacbd\ud560 \uc218 \uc788\uc73c\uba70, \ubcc0\uacbd \uc2dc \uc2dc\ud589\uc77c 7\uc77c \uc804(\ubd88\ub9ac\ud55c \ubcc0\uacbd\uc740 30\uc77c \uc804)\uc5d0 \uacf5\uc9c0\ud569\ub2c8\ub2e4.\n3. \ud68c\uc6d0\uc774 \ubcc0\uacbd\ub41c \uc57d\uad00\uc5d0 \ub3d9\uc758\ud558\uc9c0 \uc54a\uc744 \uacbd\uc6b0 \uc11c\ube44\uc2a4 \uc774\uc6a9\uc744 \uc911\ub2e8\ud558\uace0 \ud0c8\ud1f4\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.\n\n### \uc81c4\uc870 (\ud68c\uc6d0\uac00\uc785 \ubc0f \uacc4\uc815 \uad00\ub9ac)\n1. \ud68c\uc6d0\uac00\uc785\uc740 \ubcf8 \uc57d\uad00 \ubc0f \uac1c\uc778\uc815\ubcf4\ucc98\ub9ac\ubc29\uce68\uc5d0 \ub3d9\uc758\ud568\uc73c\ub85c\uc368 \uc131\ub9bd\ud569\ub2c8\ub2e4.\n2. \ud68c\uc6d0\uc740 \uac00\uc785 \uc2dc \uc815\ud655\ud55c \uc815\ubcf4\ub97c \uc81c\uacf5\ud560 \uc758\ubb34\uac00 \uc788\uc73c\uba70, \ud5c8\uc704 \uc815\ubcf4\ub85c \uc778\ud55c \ubd88\uc774\uc775\uc740 \ud68c\uc6d0\uc5d0\uac8c \uadc0\uc18d\ub429\ub2c8\ub2e4.\n3. \ud68c\uc6d0\uc740 \uc790\uc2e0\uc758 \uacc4\uc815 \uc815\ubcf4(\ube44\ubc00\ubc88\ud638 \ub4f1)\ub97c \ud0c0\uc778\uc5d0\uac8c \uc591\ub3c4\ud558\uac70\ub098 \uacf5\uc720\ud560 \uc218 \uc5c6\uc2b5\ub2c8\ub2e4.\n4. \ud68c\uc0ac\ub294 \ub2e4\uc74c\uc758 \uacbd\uc6b0 \ud68c\uc6d0\uac00\uc785\uc744 \uac70\uc808\ud558\uac70\ub098 \ud68c\uc6d0\uc790\uaca9\uc744 \ubc15\ud0c8\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4:\n   - \ud0c0\uc778\uc758 \uba85\uc758\ub97c \ub3c4\uc6a9\ud55c \uacbd\uc6b0\n   - \uc11c\ube44\uc2a4 \uc6b4\uc601\uc744 \ubc29\ud574\ud558\uac70\ub098 \ub2e4\ub978 \ud68c\uc6d0\uc5d0\uac8c \ud53c\ud574\ub97c \uc8fc\ub294 \uacbd\uc6b0\n   - \uad00\uacc4 \ubc95\ub839\uc744 \uc704\ubc18\ud55c \uacbd\uc6b0\n\n### \uc81c5\uc870 (\uc11c\ube44\uc2a4\uc758 \uc81c\uacf5)\n1. \ud68c\uc0ac\ub294 \ub2e4\uc74c\uc758 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4:\n   - \uad00\ub9ac\ube44 \uccad\uad6c\xb7\ub0a9\ubd80 \uad00\ub9ac\n   - \ube4c\ub77c \uacf5\uc9c0\xb7\ubbfc\uc6d0\xb7\ucee4\ubba4\ub2c8\ud2f0\n   - \uc8fc\ucc28 \uad00\ub9ac\n   - \uc815\uae30\uacb0\uc81c(\uad6c\ub3c5) \ubc0f \uc77c\ud68c\uc131 \uacb0\uc81c (\ud1a0\uc2a4\ud398\uc774\uba3c\uce20 \uc5f0\ub3d9)\n   - \ud478\uc2dc \uc54c\ub9bc\n2. \uc11c\ube44\uc2a4\ub294 \uc5f0\uc911\ubb34\ud734 24\uc2dc\uac04 \uc81c\uacf5\ud568\uc744 \uc6d0\uce59\uc73c\ub85c \ud558\ub098, \uc2dc\uc2a4\ud15c \uc810\uac80\xb7\uc7a5\uc560\xb7\ucc9c\uc7ac\uc9c0\ubcc0 \ub4f1\uc758 \uc0ac\uc720\ub85c \uc77c\uc2dc \uc911\ub2e8\ub420 \uc218 \uc788\uc2b5\ub2c8\ub2e4.\n\n### \uc81c6\uc870 (\uc694\uae08 \ubc0f \uacb0\uc81c)\n1. \uad00\ub9ac\uc790 \ud68c\uc6d0\uc740 \ub4f1\ub85d\ud55c \ube4c\ub77c \uc218\uc5d0 \ub530\ub77c \uc6d4 \uad6c\ub3c5\ub8cc\ub97c \uc9c0\ubd88\ud569\ub2c8\ub2e4:\n   - \uc18c\ud615 (8\uc138\ub300 \uc774\ud558): \uc6d4 30,000\uc6d0\n   - \uc778\uae30 (9~15\uc138\ub300): \uc6d4 50,000\uc6d0\n   - \ub300\ud615 (16~30\uc138\ub300): \uc6d4 70,000\uc6d0\n2. \uccab \uac00\uc785 \uc2dc 30\uc77c \ubb34\ub8cc\uccb4\ud5d8\uc774 \uc81c\uacf5\ub429\ub2c8\ub2e4.\n3. \uacb0\uc81c\ub294 \ub4f1\ub85d\ub41c \uce74\ub4dc\ub85c \ub9e4\uc6d4 \uc790\ub3d9 \uccad\uad6c\ub418\uba70, \uacb0\uc81c \uc2e4\ud328 \uc2dc \uc7ac\uc2dc\ub3c4(D+3, D+7) \ud6c4 \uc11c\ube44\uc2a4 \uc77c\uc2dc \uc815\uc9c0\ub420 \uc218 \uc788\uc2b5\ub2c8\ub2e4.\n4. \uc785\uc8fc\ubbfc\uc758 \uad00\ub9ac\ube44 \ub0a9\ubd80\ub294 \ud68c\uc0ac\uac00 \uc911\uacc4\ud558\uc9c0 \uc54a\uc73c\uba70, \ube4c\ub77c \uad00\ub9ac\uc790\uac00 \uc815\ud55c \uacc4\uc88c \ub610\ub294 \ud1a0\uc2a4\ud398\uc774\uba3c\uce20\ub97c \ud1b5\ud574 \uc9c1\uc811 \uacb0\uc81c\ub429\ub2c8\ub2e4.\n\n### \uc81c7\uc870 (\uad6c\ub3c5 \ud574\uc9c0 \ubc0f \ud658\ubd88)\n1. \ud68c\uc6d0\uc740 \uc5b8\uc81c\ub4e0\uc9c0 \uad6c\ub3c5\uc744 \ud574\uc9c0\ud560 \uc218 \uc788\uc73c\uba70, \ud574\uc9c0 \uc2dc\uc810\ubd80\ud130 \ub2e4\uc74c \uacb0\uc81c\ub294 \uccad\uad6c\ub418\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4.\n2. \uc774\ubbf8 \uacb0\uc81c\ub41c \uad6c\ub3c5\ub8cc\ub294 \uc6d0\uce59\uc801\uc73c\ub85c \ud658\ubd88\ub418\uc9c0 \uc54a\uc73c\ub098, \ud68c\uc0ac\uc758 \uadc0\ucc45\uc0ac\uc720(\uc11c\ube44\uc2a4 \uc7a5\uc560 \ub4f1)\ub85c \uc778\ud55c \ud658\ubd88\uc740 \ubcc4\ub3c4 \uac80\ud1a0\ud569\ub2c8\ub2e4.\n3. \ud658\ubd88\uc740 \uacb0\uc81c\uc77c\ub85c\ubd80\ud130 7\uc77c \uc774\ub0b4, \uc11c\ube44\uc2a4 \ubbf8\uc0ac\uc6a9 \uc0c1\ud0dc\uc5d0\uc11c\ub9cc \uc804\uc561 \ud658\ubd88 \uac00\ub2a5\ud569\ub2c8\ub2e4.\n\n### \uc81c8\uc870 (\ud68c\uc6d0\uc758 \uc758\ubb34)\n1. \ud68c\uc6d0\uc740 \ub2e4\uc74c \ud589\uc704\ub97c \ud558\uc5ec\uc11c\ub294 \uc548 \ub429\ub2c8\ub2e4:\n   - \ud0c0\uc778\uc758 \uc815\ubcf4 \ub3c4\uc6a9\n   - \ud68c\uc0ac \ub610\ub294 \uc81c3\uc790\uc758 \uc800\uc791\uad8c\xb7\uc9c0\uc2dd\uc7ac\uc0b0\uad8c \uce68\ud574\n   - \uc11c\ube44\uc2a4 \uc6b4\uc601\uc744 \ubc29\ud574\ud558\ub294 \ud589\uc704\n   - \uc74c\ub780\xb7\ud3ed\ub825\xb7\ucc28\ubcc4 \ub4f1 \uacf5\uacf5\uc9c8\uc11c\ub97c \ud574\uce58\ub294 \ucf58\ud150\uce20 \uac8c\uc2dc\n   - \uc11c\ube44\uc2a4\ub97c \uc601\ub9ac \ubaa9\uc801\uc73c\ub85c \ubb34\ub2e8 \uc774\uc6a9\n\n### \uc81c9\uc870 (\ud68c\uc0ac\uc758 \uc758\ubb34 \ubc0f \uba74\ucc45)\n1. \ud68c\uc0ac\ub294 \uc548\uc815\uc801\uc778 \uc11c\ube44\uc2a4 \uc81c\uacf5\uc744 \uc704\ud574 \ub178\ub825\ud558\ub098, \ub2e4\uc74c\uc758 \uacbd\uc6b0 \ucc45\uc784\uc744 \uc9c0\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4:\n   - \ucc9c\uc7ac\uc9c0\ubcc0\xb7\uc804\uc7c1\xb7\uc815\uc804\xb7\ud1b5\uc2e0\uc7a5\uc560 \ub4f1 \ubd88\uac00\ud56d\ub825\uc5d0 \uc758\ud55c \uc190\ud574\n   - \ud68c\uc6d0 \ubcf8\uc778\uc758 \uace0\uc758\xb7\uacfc\uc2e4\uc5d0 \uc758\ud55c \uc190\ud574\n   - \ud68c\uc6d0\uc774 \uac8c\uc2dc\ud55c \ucf58\ud150\uce20\ub85c \uc778\ud55c \ubd84\uc7c1\n   - \ubb34\ub8cc \uc11c\ube44\uc2a4 \uc774\uc6a9 \uc911 \ubc1c\uc0dd\ud55c \uc190\ud574\n2. \ud68c\uc0ac\ub294 \uacb0\uc81c \ucc98\ub9ac\ub97c \ud1a0\uc2a4\ud398\uc774\uba3c\uce20\uc5d0 \uc704\ud0c1\ud558\uba70, \uacb0\uc81c \uad00\ub828 \ubd84\uc7c1\uc740 \ud1a0\uc2a4\ud398\uc774\uba3c\uce20 \uc57d\uad00\uc5d0 \ub530\ub985\ub2c8\ub2e4.\n\n### \uc81c10\uc870 (\uac1c\uc778\uc815\ubcf4 \ubcf4\ud638)\n\ud68c\uc6d0\uc758 \uac1c\uc778\uc815\ubcf4 \ucc98\ub9ac\uc5d0 \uad00\ud55c \uc0ac\ud56d\uc740 \ubcc4\ub3c4\uc758 \"\uac1c\uc778\uc815\ubcf4\ucc98\ub9ac\ubc29\uce68\"\uc744 \ub530\ub985\ub2c8\ub2e4.\n\n### \uc81c11\uc870 (\ubd84\uc7c1 \ud574\uacb0 \ubc0f \uad00\ud560)\n1. \ubcf8 \uc57d\uad00\uc5d0 \uba85\uc2dc\ub418\uc9c0 \uc54a\uc740 \uc0ac\ud56d\uc740 \uad00\uacc4 \ubc95\ub839 \ubc0f \uc0c1\uad00\uc2b5\uc5d0 \ub530\ub985\ub2c8\ub2e4.\n2. \uc11c\ube44\uc2a4 \uc774\uc6a9 \uc911 \ubc1c\uc0dd\ud55c \ubd84\uc7c1\uc740 \uc11c\uc6b8\uc911\uc559\uc9c0\ubc29\ubc95\uc6d0\uc744 \uad00\ud560\ub85c \ud569\ub2c8\ub2e4.\n\n### \uc81c12\uc870 (\uc0ac\uc5c5\uc790 \uc815\ubcf4 \ubc0f \ubb38\uc758\ucc98)\n- \ud68c\uc0ac\uba85: \uc564\ub274 (ANDNEW)\n- \ub300\ud45c\uc790: \uc2e0\uacbd\uc544\n- \uc8fc\uc18c: \uc11c\uc6b8\ud2b9\ubcc4\uc2dc \uc1a1\ud30c\uad6c \uc1a1\ud30c\ub300\ub85c 111\n- \uc0ac\uc5c5\uc790\ub4f1\ub85d\ubc88\ud638: 296-86-02637\n- \ud1b5\uc2e0\ud310\ub9e4\uc5c5\uc2e0\uace0\ubc88\ud638: (\uc2e0\uace0 \ud6c4 \uae30\uc7ac)\n- \uace0\uac1d\uc13c\ud130(\uc774\uba54\uc77c): villatolk@andnew.kr\n\n\ubd80\uce59: \ubcf8 \uc57d\uad00\uc740 2026\ub144 4\uc6d4 27\uc77c\ubd80\ud130 \uc2dc\ud589\ub429\ub2c8\ub2e4.\n"},1117,[]);
__d(function(g,r,i,a,m,e,d){Object.defineProperty(e,"__esModule",{value:!0}),e.PRIVACY_VERSION=e.PRIVACY_POLICY=e.PRIVACY_CONSENT_SUMMARY=void 0;e.PRIVACY_VERSION='2026-04-27',e.PRIVACY_POLICY="## \ube4c\ub77c\ud1a1(ANDNEW) \uac1c\uc778\uc815\ubcf4\ucc98\ub9ac\ubc29\uce68\n\n\uc564\ub274(ANDNEW, \uc774\ud558 \"\ud68c\uc0ac\")\ub294 \ube4c\ub77c\ud1a1 \uc11c\ube44\uc2a4 \uc774\uc6a9\uc790\uc758 \uac1c\uc778\uc815\ubcf4\ub97c \uc911\uc694\uc2dc\ud558\uba70, \u300c\uac1c\uc778\uc815\ubcf4 \ubcf4\ud638\ubc95\u300d \ubc0f \uad00\ub828 \ubc95\ub839\uc744 \uc900\uc218\ud569\ub2c8\ub2e4.\n\n### \uc81c1\uc870 (\uc218\uc9d1\ud558\ub294 \uac1c\uc778\uc815\ubcf4 \ud56d\ubaa9)\n1. **\ud68c\uc6d0\uac00\uc785 \uc2dc \uc218\uc9d1 (\uad00\ub9ac\uc790)**\n   - \ud544\uc218: \uc774\uba54\uc77c, \ube44\ubc00\ubc88\ud638(\uc554\ud638\ud654 \uc800\uc7a5), \uc774\ub984, \ud734\ub300\uc804\ud654\ubc88\ud638\n   - \uc120\ud0dd: \ud504\ub85c\ud544 \uc0ac\uc9c4\n2. **\uc785\uc8fc\ubbfc \ub4f1\ub85d \uc2dc \uc218\uc9d1 (\uad00\ub9ac\uc790\uac00 \uc785\ub825)**\n   - \ud544\uc218: \uc774\ub984, \ud734\ub300\uc804\ud654\ubc88\ud638, \ud638\uc2e4\n   - \uc120\ud0dd: \uc785\uc8fc\uc77c, \ucc28\ub7c9\ubc88\ud638\n3. **\uacb0\uc81c \uc2dc \uc218\uc9d1**\n   - \uce74\ub4dc \uc815\ubcf4\ub294 \ud1a0\uc2a4\ud398\uc774\uba3c\uce20\uac00 \uc9c1\uc811 \ucc98\ub9ac\ud558\uba70, \ud68c\uc0ac\ub294 \uce74\ub4dc\uc0ac\uba85\xb7\uce74\ub4dc \ub9c8\uc9c0\ub9c9 4\uc790\ub9ac\ub9cc \uc800\uc7a5\ud569\ub2c8\ub2e4.\n   - \uccad\uad6c\uae08\uc561, \uacb0\uc81c\uc77c\uc2dc\n4. **\uc11c\ube44\uc2a4 \uc774\uc6a9 \uc911 \uc790\ub3d9 \uc218\uc9d1**\n   - \uc811\uc18d IP, \uae30\uae30 \uc2dd\ubcc4\uc790(FCM \ud1a0\ud070), \uc571 \uc0ac\uc6a9 \ub85c\uadf8, \uc811\uc18d \uc77c\uc2dc\n5. **\ubbfc\uc6d0/\ubb38\uc758 \uc2dc \uc218\uc9d1**\n   - \uc791\uc131 \ub0b4\uc6a9, \ucca8\ubd80 \uc774\ubbf8\uc9c0\n\n### \uc81c2\uc870 (\uac1c\uc778\uc815\ubcf4\uc758 \uc218\uc9d1 \ubc0f \uc774\uc6a9 \ubaa9\uc801)\n\ud68c\uc0ac\ub294 \uc218\uc9d1\ud55c \uac1c\uc778\uc815\ubcf4\ub97c \ub2e4\uc74c \ubaa9\uc801\uc73c\ub85c\ub9cc \uc774\uc6a9\ud569\ub2c8\ub2e4:\n1. \ud68c\uc6d0 \uc2dd\ubcc4 \ubc0f \ubcf8\uc778 \ud655\uc778\n2. \uc11c\ube44\uc2a4 \uc81c\uacf5 (\uad00\ub9ac\ube44 \uccad\uad6c\xb7\ub0a9\ubd80, \uacf5\uc9c0, \ubbfc\uc6d0 \ucc98\ub9ac)\n3. \uacb0\uc81c \ubc0f \uc815\uc0b0\n4. \ud478\uc2dc \uc54c\ub9bc \ubc1c\uc1a1 (\uacf5\uc9c0\xb7\uccad\uad6c\xb7\uacb0\uc81c \uacb0\uacfc)\n5. \uace0\uac1d \uc9c0\uc6d0 \ubc0f \ubd84\uc7c1 \ud574\uacb0\n6. \uc11c\ube44\uc2a4 \uac1c\uc120\uc744 \uc704\ud55c \ud1b5\uacc4 \ubd84\uc11d (\uac1c\uc778 \uc2dd\ubcc4 \ubd88\uac00\ub2a5\ud55c \ud615\ud0dc)\n7. \uad00\ub828 \ubc95\ub839\uc5d0 \ub530\ub978 \uc758\ubb34 \uc774\ud589\n\n### \uc81c3\uc870 (\uac1c\uc778\uc815\ubcf4\uc758 \ubcf4\uc720 \ubc0f \uc774\uc6a9 \uae30\uac04)\n1. \uc6d0\uce59\uc801\uc73c\ub85c \uac1c\uc778\uc815\ubcf4\ub294 \uc218\uc9d1\xb7\uc774\uc6a9 \ubaa9\uc801 \ub2ec\uc131 \uc2dc \uc9c0\uccb4 \uc5c6\uc774 \ud30c\uae30\ud569\ub2c8\ub2e4.\n2. \ub2e8, \ub2e4\uc74c\uc758 \uacbd\uc6b0 \uba85\uc2dc\ud55c \uae30\uac04 \ub3d9\uc548 \ubcf4\uad00\ud569\ub2c8\ub2e4:\n   - **\ud68c\uc6d0 \ud0c8\ud1f4 \ud6c4**: \ubd80\uc815 \uc774\uc6a9 \ubc29\uc9c0 \ubaa9\uc801\uc73c\ub85c 30\uc77c \ubcf4\uad00 \ud6c4 \ud30c\uae30\n   - **\uacb0\uc81c \uae30\ub85d**: \u300c\uc804\uc790\uc0c1\uac70\ub798\ubc95\u300d\uc5d0 \ub530\ub77c 5\ub144\n   - **\uc18c\ube44\uc790 \ubd88\ub9cc/\ubd84\uc7c1**: \u300c\uc804\uc790\uc0c1\uac70\ub798\ubc95\u300d\uc5d0 \ub530\ub77c 3\ub144\n   - **\ub85c\uadf8\uc778 \uae30\ub85d**: \u300c\ud1b5\uc2e0\ube44\ubc00\ubcf4\ud638\ubc95\u300d\uc5d0 \ub530\ub77c 3\uac1c\uc6d4\n\n### \uc81c4\uc870 (\uac1c\uc778\uc815\ubcf4\uc758 \uc81c3\uc790 \uc81c\uacf5)\n\ud68c\uc0ac\ub294 \ud68c\uc6d0\uc758 \uac1c\uc778\uc815\ubcf4\ub97c \uc678\ubd80\uc5d0 \uc81c\uacf5\ud558\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4. \ub2e8, \uc544\ub798\uc758 \uacbd\uc6b0 \uc608\uc678\ub85c \ud569\ub2c8\ub2e4:\n1. \ud68c\uc6d0\uc774 \uc0ac\uc804\uc5d0 \ub3d9\uc758\ud55c \uacbd\uc6b0\n2. \ubc95\ub839\uc5d0 \ub530\ub77c \uc218\uc0ac\uae30\uad00\uc758 \uc694\uccad\uc774 \uc788\ub294 \uacbd\uc6b0\n\n### \uc81c5\uc870 (\uac1c\uc778\uc815\ubcf4\uc758 \ucc98\ub9ac \uc704\ud0c1)\n\ud68c\uc0ac\ub294 \uc11c\ube44\uc2a4 \uc81c\uacf5\uc744 \uc704\ud574 \uc544\ub798 \uc5c5\uccb4\uc5d0 \uac1c\uc778\uc815\ubcf4 \ucc98\ub9ac\ub97c \uc704\ud0c1\ud569\ub2c8\ub2e4:\n\n| \uc704\ud0c1\ubc1b\ub294 \uc790 | \uc704\ud0c1 \uc5c5\ubb34 | \ubcf4\uc720\xb7\uc774\uc6a9 \uae30\uac04 |\n|---|---|---|\n| Supabase Inc. | \ub370\uc774\ud130\ubca0\uc774\uc2a4 \ud638\uc2a4\ud305, \uc778\uc99d | \ud68c\uc6d0 \ud0c8\ud1f4 \uc2dc\uae4c\uc9c0 |\n| \ud1a0\uc2a4\ud398\uc774\uba3c\uce20 | \uacb0\uc81c \ucc98\ub9ac, \ube4c\ub9c1\ud0a4 \uad00\ub9ac | \uacb0\uc81c\uc77c\ub85c\ubd80\ud130 5\ub144 |\n| Google (Firebase / Expo) | \ud478\uc2dc \uc54c\ub9bc \ubc1c\uc1a1 | \ud68c\uc6d0 \ud0c8\ud1f4 \uc2dc\uae4c\uc9c0 |\n| Vercel Inc. | \uad00\ub9ac\uc790 \uc6f9 \ud638\uc2a4\ud305 | \uc11c\ube44\uc2a4 \uc885\ub8cc \uc2dc\uae4c\uc9c0 |\n\n\uc704\ud0c1 \uc2dc \u300c\uac1c\uc778\uc815\ubcf4 \ubcf4\ud638\ubc95\u300d\uc5d0 \ub530\ub77c \uc548\uc804\ud55c \ucc98\ub9ac\uac00 \uac00\ub2a5\ud558\ub3c4\ub85d \uad00\ub9ac\xb7\uac10\ub3c5\ud569\ub2c8\ub2e4.\n\n### \uc81c6\uc870 (\uac1c\uc778\uc815\ubcf4\uc758 \uad6d\uc678\uc774\uc804)\n\uc77c\ubd80 \uc704\ud0c1\uc5c5\uccb4(Supabase, Vercel \ub4f1)\ub294 \uad6d\uc678\uc5d0 \uc11c\ubc84\ub97c \ub450\uace0 \uc788\uc5b4, \ud68c\uc6d0\uc758 \uac1c\uc778\uc815\ubcf4\uac00 \uad6d\uc678\ub85c \uc774\uc804\ub420 \uc218 \uc788\uc2b5\ub2c8\ub2e4.\n- \uc774\uc804\uad6d\uac00: \ubbf8\uad6d, \uc2f1\uac00\ud3ec\ub974 (Supabase Asia \ub9ac\uc804 \uc0ac\uc6a9 \uc2dc)\n- \uc774\uc804 \ud56d\ubaa9: \ubcf8 \ubc29\uce68 \uc81c1\uc870\uc758 \ubaa8\ub4e0 \uc218\uc9d1 \ud56d\ubaa9\n- \uc774\uc804 \uc77c\uc2dc \ubc0f \ubc29\ubc95: \uc11c\ube44\uc2a4 \uc774\uc6a9 \uc2dc \uc2e4\uc2dc\uac04, \uc554\ud638\ud654 \ud1b5\uc2e0\n- \ubcf4\uc720 \ubc0f \uc774\uc6a9 \uae30\uac04: \ubcf8 \ubc29\uce68 \uc81c3\uc870\uc640 \ub3d9\uc77c\n\n### \uc81c7\uc870 (\uc774\uc6a9\uc790\uc758 \uad8c\ub9ac)\n\ud68c\uc6d0\uc740 \uc5b8\uc81c\ub4e0\uc9c0 \ub2e4\uc74c\uc758 \uad8c\ub9ac\ub97c \ud589\uc0ac\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4:\n1. \uac1c\uc778\uc815\ubcf4 \uc5f4\ub78c \uc694\uccad\n2. \uc624\ub958 \uc815\uc815 \uc694\uccad\n3. \uc0ad\uc81c \uc694\uccad (\ud68c\uc6d0 \ud0c8\ud1f4 \ud3ec\ud568)\n4. \ucc98\ub9ac \uc815\uc9c0 \uc694\uccad\n\u203b \uc774\uc6a9\uc790\uac00 \uad8c\ub9ac\ub97c \ud589\uc0ac\ud558\ub824\uba74 villatolk@andnew.kr \ub85c \uc5f0\ub77d\ud558\uc2dc\uae30 \ubc14\ub78d\ub2c8\ub2e4.\n\n### \uc81c8\uc870 (\uac1c\uc778\uc815\ubcf4\uc758 \uc548\uc804\uc131 \ud655\ubcf4 \uc870\uce58)\n\ud68c\uc0ac\ub294 \uac1c\uc778\uc815\ubcf4 \ubcf4\ud638\ub97c \uc704\ud574 \ub2e4\uc74c\uc758 \uc870\uce58\ub97c \ucde8\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4:\n1. \ube44\ubc00\ubc88\ud638 \uc554\ud638\ud654 \uc800\uc7a5 (\ub2e8\ubc29\ud5a5 \ud574\uc2dc)\n2. \ud1b5\uc2e0 \uad6c\uac04 \uc554\ud638\ud654 (HTTPS/TLS)\n3. \uac1c\uc778\uc815\ubcf4 \ucc98\ub9ac \uc9c1\uc6d0 \ucd5c\uc18c\ud654 \ubc0f \uc815\uae30 \uad50\uc721\n4. \uc811\uadfc \uad8c\ud55c \ud1b5\uc81c\n5. \uc815\uae30\uc801\uc778 \ubcf4\uc548 \uc810\uac80\n\n### \uc81c9\uc870 (\ub9cc 14\uc138 \ubbf8\ub9cc \uc544\ub3d9\uc758 \uac1c\uc778\uc815\ubcf4)\n\ud68c\uc0ac\ub294 \ub9cc 14\uc138 \ubbf8\ub9cc \uc544\ub3d9\uc758 \ud68c\uc6d0\uac00\uc785\uc744 \ubc1b\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4.\n\n### \uc81c10\uc870 (\uac1c\uc778\uc815\ubcf4 \ubcf4\ud638\ucc45\uc784\uc790)\n- \ud68c\uc0ac\uba85: \uc564\ub274 (ANDNEW)\n- \ub300\ud45c\uc790/\ubcf4\ud638\ucc45\uc784\uc790: \uc2e0\uacbd\uc544 (\ub300\ud45c\uc640 \ub3d9\uc77c)\n- \uc8fc\uc18c: \uc11c\uc6b8\ud2b9\ubcc4\uc2dc \uc1a1\ud30c\uad6c \uc1a1\ud30c\ub300\ub85c 111\n- \uc0ac\uc5c5\uc790\ub4f1\ub85d\ubc88\ud638: 296-86-02637\n- \uc5f0\ub77d\ucc98(\uc774\uba54\uc77c): villatolk@andnew.kr\n\n### \uc81c11\uc870 (\ubc29\uce68\uc