# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbG...
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...
SUPABASE_JWT_SECRET=xxxxx

# 토스페이먼츠
TOSS_CLIENT_KEY=test_ck_xxxx
TOSS_SECRET_KEY=test_sk_xxxx
TOSS_WEBHOOK_SECRET=xxxx

# Firebase
FIREBASE_PROJECT_ID=andnew-xxxxx
FIREBASE_SERVICE_ACCOUNT_KEY='{...}'

# App 설정
APP_ENV=development
ADMIN_WEB_URL=https://admin.andnew.kr
DEEP_LINK_SCHEME=andnew://

# 다날 본인확인 (BARO)
# https://www.danal.co.kr 가입 후 발급. 둘 다 발급되면 admin-web .env.local 에 입력
DANAL_CPID=
DANAL_CPPWD=
# 운영: https://uas.teledit.com / 개발: https://uasdev.teledit.com 처럼 분리 가능
DANAL_API_BASE=https://uas.teledit.com
# 모바일 앱이 호출할 admin-web base URL (= ADMIN_WEB_URL 과 동일)
EXPO_PUBLIC_DANAL_API_BASE=https://admin.andnew.kr
# 다날 키 발급 전 본인인증 강제 통과 — 출시 직전 0 또는 제거
# 1: 본인인증 버튼 즉시 성공 처리
# 0/미설정: 정상 다날 본인확인 진행
EXPO_PUBLIC_BYPASS_PASS_AUTH=0

# Vercel Cron 보호 (옵션)
CRON_SECRET=
